# Copy to docker/.env (never commit docker/.env)
# FortiMail Engine (required)
FORTIMAIL_ENGINE_URL=https://engine.example.com/v1
FORTIMAIL_ENGINE_API_KEY=fme_replace_me

# MCP HTTP auth — REQUIRED if this service is reachable beyond localhost.
# If both are unset, POST /mcp is unrestricted (see SECURITY.md).
MCP_HTTP_BEARER_TOKEN=replace_with_long_random_string

# Optional: X-API-Key header instead of/in addition to Bearer
# MCP_HTTP_API_KEY=

# TLS to engine (omit or true in production)
# FORTIMAIL_VERIFY_CERT=true

# Cache: memory (default) or redis
FORTIMAIL_CACHE_BACKEND=memory
# REDIS_URL=redis://:password@redis:6379/0
