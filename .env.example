# FortiMail Engine (required) — base URL must include /v1
FORTIMAIL_ENGINE_URL=https://engine.example.com/v1
FORTIMAIL_ENGINE_API_KEY=fme_

# Optional: set to false only for dev / private CA (default: verify TLS)
# FORTIMAIL_VERIFY_CERT=false

# Optional cache
# FORTIMAIL_CACHE_BACKEND=redis
# REDIS_URL=redis://127.0.0.1:6379

# HTTP transport — protect MCP endpoint when not localhost:
# MCP_HTTP_BEARER_TOKEN=your-secret
# MCP_HTTP_API_KEY=your-api-key
# MCP_HTTP_HOST=127.0.0.1
